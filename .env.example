# Vaani-AI environment variables
# Copy this file to .env.local and fill in real values.

# --- AI / external services ---
GROQ_API_KEY=your_groq_api_key
GEMINI_API_KEY=your_gemini_api_key
RESEND_API_KEY=your_resend_api_key
FROM_EMAIL=onboarding@resend.dev

# --- App config ---
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# SUBMISSION_DB_FILE=data/submissions.json

# --- Admin authentication ---
# Server-side secret required to authorize protected admin API operations.
# Fails closed: if unset, those operations are rejected.
ADMIN_SECRET_KEY=your_admin_secret_key

# Client-side admin key used by the admin dashboard UI for API calls.
NEXT_PUBLIC_ADMIN_KEY=your_admin_key

# Secret used to derive per-service admin login passwords in the admin portal.
# Each admin password is `${NEXT_PUBLIC_ADMIN_PASSWORD_SECRET}@${serviceKey}`,
# e.g. with secret "admin" the Aadhaar admin password is "admin@aadhaar".
# REQUIRED: if unset, the admin credential table is empty and ALL admin logins fail.
NEXT_PUBLIC_ADMIN_PASSWORD_SECRET=your_admin_password_secret
